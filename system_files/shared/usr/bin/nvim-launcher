#!/bin/bash
# nvim-launcher - Launch the Hypercube AI-first Neovim sandbox
#
# The editor + AI agents ship as a podman image run via ~/.local/bin/nvim.
# On first use this installs the wrapper (pulling the image), then execs it.

NVIM_BIN="$HOME/.local/bin/nvim"

if [ ! -x "$NVIM_BIN" ]; then
    echo "Neovim Sandbox"
    echo "=============="
    echo ""
    echo "The Neovim sandbox is not set up yet."
    echo ""
    echo "This will pull the image (several GB on first run) and install the"
    echo "'nvim' launcher to ~/.local/bin."
    echo ""
    read -p "Set up now? [Y/n] " -n 1 -r
    echo ""

    if [[ $REPLY =~ ^[Nn]$ ]]; then
        echo "Setup cancelled. Run 'ujust nvim-setup' when ready."
        read -p "Press Enter to close..."
        exit 0
    fi

    echo ""
    ujust nvim-setup
fi

if [ -x "$NVIM_BIN" ]; then
    exec "$NVIM_BIN" "$@"
else
    echo "Setup may have failed. Try running 'ujust nvim-setup' manually."
    read -p "Press Enter to close..."
    exit 1
fi
