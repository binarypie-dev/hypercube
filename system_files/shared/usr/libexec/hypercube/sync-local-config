#!/usr/bin/bash
# sync-local-config — drop the image-baked editor/multiplexer config into the
# user's ~/.config so the LOCAL `nvim` and `zellij` run preconfigured, sharing
# the SAME configuration that ships baked inside the devcube container image.
#
# Hypercube bakes the dotfiles into a pristine, read-only path under
# /usr/share/hypercube/config (Containerfile: `COPY dot_files ...`). That path
# is not enough on its own: nvim does not read $XDG_CONFIG_DIRS for its init,
# and zellij only loads ~/.config/zellij or /etc/zellij — so neither tool can
# pick up a config straight from the shared path. We therefore place a COPY in
# ~/.config, exactly as the devcube entrypoint does inside the container, just
# here on the host.
#
# These dirs are image-owned: the copy is replaced whenever the baked config
# differs, so config updates ship with the image (`bootc upgrade`) instead of
# going stale on the user's home. Personal nvim plugins live in
# ~/.config/hypercube/nvim and are layered on top (see
# nvim/config/lua/config/lazy.lua); they are never touched here.
#
# Invoked from the host fish login config (fish/conf.d/20-local-config.fish).
# A no-op inside the devcube container, where the entrypoint already syncs.
set -euo pipefail

# Inside the devcube container the entrypoint owns the sync; nothing to do.
[ -n "${DEVCUBE:-}" ] && exit 0

config_src="/usr/share/hypercube/config"
dest_root="${XDG_CONFIG_HOME:-$HOME/.config}"

# Replace $dest with a fresh copy of $src when they differ. `diff -rq` is exact
# and cheap for these few small files, so an already-current shell start does
# nothing (and never clobbers a copy that still matches the image).
sync_one() {
    local src="$1" dest="$2"
    [ -d "$src" ] || return 0

    if [ -d "$dest" ] && diff -rq "$src" "$dest" >/dev/null 2>&1; then
        return 0
    fi

    # Stage a fresh copy beside the dest, then swap it in with an atomic rename
    # (same filesystem). cp -a — not rsync, which we don't depend on at runtime
    # — so a file removed from the image also drops from the copy.
    mkdir -p "$dest_root"
    local staging
    staging="$(mktemp -d "${dest}.XXXXXX")"
    cp -a "$src/." "$staging/"
    rm -rf "$dest"
    mv "$staging" "$dest"
}

# nvim's runtime config is the inner config/ dir; the parent also carries
# dev-only files (.neoconf.json, stylua.toml) that aren't part of the runtime.
sync_one "$config_src/nvim/config" "$dest_root/nvim"
# zellij ships its config.kdl plus layouts/ (e.g. the workmux layout).
sync_one "$config_src/zellij" "$dest_root/zellij"
