# Hypercube Ghostty configuration.
#
# Ghostty is a plain, chrome-less renderer. Multiplexing — tabs, splits, panes —
# is owned by zellij (leader Ctrl+Space; see KEYBINDINGS.md and
# dot_files/zellij/config.kdl, #198), so Ghostty defines no multiplexer leader.

# ----------------------------------------------------------------
# APPLICATION - Behavior and Configuraiton
# ----------------------------------------------------------------
async-backend = auto
desktop-notifications = false
clipboard-trim-trailing-spaces = true
clipboard-read = allow
clipboard-write = allow

# ----------------------------------------------------------------
# APPEARANCE - Hide all chrome
# ----------------------------------------------------------------

window-theme = ghostty
window-decoration = none
gtk-titlebar = false
gtk-tabs-location = bottom
gtk-wide-tabs = false
gtk-toolbar-style = flat

# ----------------------------------------------------------------
# FONT CONFIGURATION
# ----------------------------------------------------------------

font-family = JetBrains Mono
font-size = 13

# ----------------------------------------------------------------
# TOKYO NIGHT MOON COLOR SCHEME
# Matching Neovim's Tokyo Night Moon theme with darker backgrounds
# ----------------------------------------------------------------

# Background and foreground
background = #222436
foreground = #c8d3f5

# Cursor
cursor-color = #c8d3f5
cursor-text = #222436

# Selection
selection-background = #2f334d
selection-foreground = #c8d3f5

# Black (terminal_black and darker variants)
palette = 0=#1e2030
palette = 8=#444a73

# Red
palette = 1=#ff757f
palette = 9=#ff757f

# Green
palette = 2=#c3e88d
palette = 10=#c3e88d

# Yellow
palette = 3=#ffc777
palette = 11=#ffc777

# Blue
palette = 4=#82aaff
palette = 12=#65bcff

# Magenta/Purple
palette = 5=#c099ff
palette = 13=#fca7ea

# Cyan
palette = 6=#86e1fc
palette = 14=#86e1fc

# White
palette = 7=#c8d3f5
palette = 15=#c8d3f5

# ----------------------------------------------------------------
# KEYBINDINGS
# ----------------------------------------------------------------
# Tabs / splits / panes are owned by zellij (leader Ctrl+Space). Ghostty keeps
# no multiplexer leader, so its keys never shadow what zellij or a focused agent
# needs — notably, dropping the old Ctrl+a prefix frees Ctrl+a as readline
# "beginning of line" when you run `devc claude` in a plain window.
#
# We keep one "new window" binding so plain local console work (outside the
# multiplexer) can still open another OS window, plus reload-config. (Ghostty's
# built-in copy/paste — Ctrl+Shift+C/V — and scrollback stay at their defaults.)
keybind = ctrl+shift+n=new_window
keybind = ctrl+shift+comma=reload_config
