// Hypercube zellij configuration.
//
// Tokyo Night Moon theme to match Neovim/Ghostty. Palette source of truth:
// dot_files/ghostty/config ("TOKYO NIGHT MOON COLOR SCHEME").
//
// We use zellij's advanced UI-component theme format (not the simple
// fg/bg/red/green… palette) on purpose. With the simple palette zellij hardwires
// the bright lime `green` (#c3e88d) onto the selected mode ribbon and active tab,
// which lights up the whole status bar — loud/"offensive". The component format
// lets us repaint that chrome with a calmer Tokyo Night Moon blue and muted
// backgrounds while keeping the same palette identity. Each component takes a
// `base` (text), a `background`, and four `emphasis_*` accent slots.
//
// Keybindings: see the unified scheme in ../../KEYBINDINGS-PROPOSAL.md (#198).
// We clear zellij's defaults and define ONE leader-entered mode instead of the
// usual pane/tab/resize/scroll/session mode soup.

themes {
    tokyo-night-moon {
        // Bare text (search paging, plain UI labels).
        text_unselected {
            base "#c8d3f5"
            background "#222436"
            emphasis_0 "#ff966c"
            emphasis_1 "#86e1fc"
            emphasis_2 "#c3e88d"
            emphasis_3 "#c099ff"
        }
        text_selected {
            base "#c8d3f5"
            background "#2f334d"
            emphasis_0 "#ff966c"
            emphasis_1 "#86e1fc"
            emphasis_2 "#c3e88d"
            emphasis_3 "#c099ff"
        }
        // Ribbons = status-bar mode pills + tabs. The selected one used to be
        // bright green; soft blue on a dark base is far easier on the eyes.
        ribbon_selected {
            base "#1e2030"
            background "#82aaff"
            emphasis_0 "#ffc777"
            emphasis_1 "#ff966c"
            emphasis_2 "#c099ff"
            emphasis_3 "#86e1fc"
        }
        ribbon_unselected {
            base "#c8d3f5"
            background "#2f334d"
            emphasis_0 "#ffc777"
            emphasis_1 "#ff966c"
            emphasis_2 "#c099ff"
            emphasis_3 "#86e1fc"
        }
        table_title {
            base "#82aaff"
            background "#222436"
            emphasis_0 "#ff966c"
            emphasis_1 "#86e1fc"
            emphasis_2 "#c3e88d"
            emphasis_3 "#c099ff"
        }
        table_cell_selected {
            base "#c8d3f5"
            background "#2f334d"
            emphasis_0 "#ff966c"
            emphasis_1 "#86e1fc"
            emphasis_2 "#c3e88d"
            emphasis_3 "#c099ff"
        }
        table_cell_unselected {
            base "#c8d3f5"
            background "#222436"
            emphasis_0 "#ff966c"
            emphasis_1 "#86e1fc"
            emphasis_2 "#c3e88d"
            emphasis_3 "#c099ff"
        }
        list_selected {
            base "#c8d3f5"
            background "#2f334d"
            emphasis_0 "#ff966c"
            emphasis_1 "#86e1fc"
            emphasis_2 "#c3e88d"
            emphasis_3 "#c099ff"
        }
        list_unselected {
            base "#c8d3f5"
            background "#222436"
            emphasis_0 "#ff966c"
            emphasis_1 "#86e1fc"
            emphasis_2 "#c3e88d"
            emphasis_3 "#c099ff"
        }
        // Focused-pane border: soft blue instead of a loud accent.
        frame_selected {
            base "#82aaff"
            background "#222436"
            emphasis_0 "#86e1fc"
            emphasis_1 "#ffc777"
            emphasis_2 "#c099ff"
            emphasis_3 "#c8d3f5"
        }
        frame_highlight {
            base "#ff966c"
            background "#222436"
            emphasis_0 "#ff966c"
            emphasis_1 "#ff966c"
            emphasis_2 "#ff966c"
            emphasis_3 "#ff966c"
        }
        exit_code_success {
            base "#c3e88d"
            background "#222436"
            emphasis_0 "#86e1fc"
            emphasis_1 "#2f334d"
            emphasis_2 "#c099ff"
            emphasis_3 "#c3e88d"
        }
        exit_code_error {
            base "#ff757f"
            background "#222436"
            emphasis_0 "#ffc777"
            emphasis_1 "#222436"
            emphasis_2 "#222436"
            emphasis_3 "#222436"
        }
        multiplayer_user_colors {
            player_1 "#c099ff"
            player_2 "#82aaff"
            player_3 "#ff966c"
            player_4 "#ffc777"
            player_5 "#86e1fc"
            player_6 "#ff757f"
            player_7 "#c3e88d"
            player_8 "#828bb8"
            player_9 "#c099ff"
            player_10 "#82aaff"
        }
    }
}

theme "tokyo-night-moon"

default_shell "fish"
scrollback_editor "nvim"
pane_frames true
default_layout "compact"

// ── Keybindings (Hypercube unified scheme) ──────────────────────────────────
// THE LEADER is Ctrl+Space. Press it to enter HYPER mode, then ONE key:
//
//   PANES    | split right · - split down · n new · x close · z zoom
//            w toggle floating · e embed/float · h/j/k/l focus · H/J/K/L move
//   TABS     c new · [ / ] prev/next · 1-9 jump (your workmux worktrees) · , rename
//   RESIZE   r  (then h/j/k/l or +/-; Esc exits)
//   SESSION  s manager · d detach (leave agents running) · q quit
//   ESCAPE   g lock (pass every key to a focused TUI; Ctrl+Space unlocks)
//   Esc / Enter returns to Normal.
//
// NO leader needed — these move focus between zellij panes from anywhere:
//   Alt h/j/k/l  move focus      Alt = / Alt -  grow / shrink pane
// (Inside Neovim, use Neovim's own Ctrl+hjkl for its splits — separate layer.)
//
// workmux ↔ zellij:  `workmux add <branch>` opens each git worktree as its own
//   TAB running the agent (see ../workmux/config.yaml). So your parallel agents
//   are zellij TABS: Ctrl+Space then [ / ] or 1-9. `workmux list` /
//   `workmux dashboard` show them all. Panes within a tab: Alt h/j/k/l.

keybinds clear-defaults=true {
    // ── Global chords: active in every mode except Locked ───────────────────
    shared_except "locked" {
        // The one leader. Ctrl+Space chosen over Ctrl+a so it never shadows
        // readline / Claude Code "beginning of line" in a focused agent pane.
        bind "Ctrl Space" { SwitchToMode "tmux"; }

        // Bare directional focus + resize — no mode, muscle memory everywhere.
        // MoveFocusOrTab so h/l also hop between tabs at the pane-grid edges.
        bind "Alt h" "Alt Left"  { MoveFocusOrTab "Left"; }
        bind "Alt l" "Alt Right" { MoveFocusOrTab "Right"; }
        bind "Alt j" "Alt Down"  { MoveFocus "Down"; }
        bind "Alt k" "Alt Up"    { MoveFocus "Up"; }
        bind "Alt =" "Alt +"     { Resize "Increase"; }
        bind "Alt -"             { Resize "Decrease"; }
    }

    // ── HYPER: the single leader mode (every action returns to Normal, so it
    //    reads like a leader sequence — Ctrl+Space | splits, Ctrl+Space c tabs).
    tmux {
        // Panes
        bind "|" { NewPane "Right"; SwitchToMode "Normal"; }
        bind "-" { NewPane "Down";  SwitchToMode "Normal"; }
        bind "n" { NewPane;         SwitchToMode "Normal"; }
        bind "x" { CloseFocus;      SwitchToMode "Normal"; }
        bind "z" { ToggleFocusFullscreen; SwitchToMode "Normal"; }
        bind "w" { ToggleFloatingPanes;   SwitchToMode "Normal"; }
        bind "e" { TogglePaneEmbedOrFloating; SwitchToMode "Normal"; }
        bind "h" { MoveFocus "Left";  SwitchToMode "Normal"; }
        bind "j" { MoveFocus "Down";  SwitchToMode "Normal"; }
        bind "k" { MoveFocus "Up";    SwitchToMode "Normal"; }
        bind "l" { MoveFocus "Right"; SwitchToMode "Normal"; }
        bind "H" { MovePane "Left";  SwitchToMode "Normal"; }
        bind "J" { MovePane "Down";  SwitchToMode "Normal"; }
        bind "K" { MovePane "Up";    SwitchToMode "Normal"; }
        bind "L" { MovePane "Right"; SwitchToMode "Normal"; }

        // Tabs (= your workmux worktrees)
        bind "c" { NewTab;          SwitchToMode "Normal"; }
        bind "[" { GoToPreviousTab; SwitchToMode "Normal"; }
        bind "]" { GoToNextTab;     SwitchToMode "Normal"; }
        bind "1" { GoToTab 1; SwitchToMode "Normal"; }
        bind "2" { GoToTab 2; SwitchToMode "Normal"; }
        bind "3" { GoToTab 3; SwitchToMode "Normal"; }
        bind "4" { GoToTab 4; SwitchToMode "Normal"; }
        bind "5" { GoToTab 5; SwitchToMode "Normal"; }
        bind "6" { GoToTab 6; SwitchToMode "Normal"; }
        bind "7" { GoToTab 7; SwitchToMode "Normal"; }
        bind "8" { GoToTab 8; SwitchToMode "Normal"; }
        bind "9" { GoToTab 9; SwitchToMode "Normal"; }
        bind "," { SwitchToMode "RenameTab"; TabNameInput 0; }

        // Resize — the one optional nested mode (Esc/Ctrl+Space exits it).
        bind "r" { SwitchToMode "Resize"; }

        // Session / agents
        bind "s" { LaunchOrFocusPlugin "zellij:session-manager" { floating true; }; SwitchToMode "Normal"; }
        bind "d" { Detach; }
        bind "q" { Quit; }

        // Lock: hand every key to a focused TUI; Ctrl+Space unlocks.
        bind "g" { SwitchToMode "Locked"; }

        // Leave the leader mode.
        bind "Esc" "Enter" "Ctrl Space" { SwitchToMode "Normal"; }
    }

    // ── Locked: pass everything through to the focused program. One key out. ──
    locked {
        bind "Ctrl Space" { SwitchToMode "Normal"; }
    }

    // ── Resize sub-mode (reached via Ctrl+Space r) ──────────────────────────
    resize {
        bind "h" "Left"  { Resize "Increase Left"; }
        bind "j" "Down"  { Resize "Increase Down"; }
        bind "k" "Up"    { Resize "Increase Up"; }
        bind "l" "Right" { Resize "Increase Right"; }
        bind "=" "+"     { Resize "Increase"; }
        bind "-"         { Resize "Decrease"; }
        bind "Esc" "Enter" "Ctrl Space" { SwitchToMode "Normal"; }
    }

    // ── Rename tab: text entry, then Enter to keep / Esc to cancel ───────────
    renametab {
        bind "Enter" { SwitchToMode "Normal"; }
        bind "Esc"   { UndoRenameTab; SwitchToMode "Normal"; }
    }
}
