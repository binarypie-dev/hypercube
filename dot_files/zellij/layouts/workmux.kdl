// workmux workspace layout (the main `devc workmux` / `devc` session): a live
// `workmux dashboard` control center stacked above a focused shell for running
// `workmux add <branch> "<prompt>"`. Each add opens its own zellij TAB with
// nvim + an agent (see ../../workmux/config.yaml).
//
// NOTES:
//  - workmux's `sidebar` is tmux-only; `dashboard` works under the zellij
//    backend (only its inline preview is disabled).
//  - The shell pane is focused and keeps the session alive even when the
//    dashboard pane is empty (no worktrees yet) or exits.
//  - split_direction="horizontal" stacks the panes (dashboard on top).
layout {
    tab name="workmux" focus=true split_direction="horizontal" {
        pane size="65%" {
            command "workmux"
            args "dashboard"
        }
        pane focus=true
    }
}
