// workmux workspace layout: a clean working shell. From here, run
// `workmux add <branch> "<prompt>"` to spin up a git worktree + a new tab
// running the configured agent (see dot_files/workmux/config.yaml).
//
// NOTE: workmux's live `sidebar` is tmux-only ("Error: Sidebar requires tmux")
// and must NOT be used under the zellij backend -- running it here made zellij
// fail to bring the session up ("There is no active session!"). Under zellij,
// check status on demand with `workmux list` (or the `workmux dashboard` TUI).
layout {
    tab name="workmux" focus=true {
        pane
    }
}
